{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Address",
  "type": "object",
  "properties": {
    "street": { "type": "string" },
    "city": { "type": "string" },
    "state": { "type": "string" },
    "postal_code": { "type": "string" },
    "country": { "type": "string" },
    "address_type": { "type": "string", "enum": ["home", "billing"] }
  },
  "required": ["street", "city", "state", "postal_code", "country", "address_type"],
  "additionalProperties": false
}
